<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <include layout="@layout/layout_app_header" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingTop="16dp"
        android:paddingBottom="80dp"
        android:paddingHorizontal="20dp"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Title -->
            <TextView
                android:id="@+id/tvProjectTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Project Endpoints"
                android:textColor="@color/on_surface"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvProjectSubtext"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:text="Manage and test your active API routes."
                android:textColor="@color/on_surface_variant"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvCollectionMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:textColor="@color/outline"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:text="Empty collection · Created today" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTestCollection"
                    style="@style/Widget.Bubbly.Button"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:text="Test Collection" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddApi"
                    style="@style/Widget.Bubbly.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="Add API"
                    app:icon="@drawable/ic_nav_add"
                    app:iconGravity="textStart" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEditCollection"
                    style="@style/Widget.Bubbly.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="Edit Collection" />
            </LinearLayout>

            <!-- Search Bar -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Bubbly.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:hintEnabled="false"
                app:startIconDrawable="@drawable/ic_nav_search"
                app:startIconTint="@color/outline">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etSearch"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="Search endpoints..."
                    android:textSize="16sp"
                    android:textColor="@color/on_surface" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Dynamic Endpoints RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvEndpoints"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_endpoint_card"
                tools:itemCount="3" />

            <LinearLayout
                android:id="@+id/emptyApiState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_dashed"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="28dp"
                android:visibility="gone"
                tools:visibility="visible">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_nav_add"
                    app:tint="@color/outline" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="No APIs yet"
                    android:textColor="@color/on_surface"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:text="Add your first API to this collection."
                    android:textColor="@color/on_surface_variant"
                    android:textSize="14sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEmptyAddApi"
                    style="@style/Widget.Bubbly.Button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="Add API"
                    app:icon="@drawable/ic_nav_add"
                    app:iconGravity="textStart" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- FAB: Add New Endpoint -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddEndpoint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="80dp"
        android:src="@drawable/ic_nav_add"
        app:backgroundTint="@color/primary_container"
        app:borderWidth="2dp"
        app:tint="@color/on_primary_container" />

    <include layout="@layout/layout_bottom_nav" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
